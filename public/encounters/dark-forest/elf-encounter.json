  },
  "texts": [
    "Halt, Fremder! Du wagst dich tief in den Düsterwald...",
    "Ich bin Nyllara, Hüterin der uralten Bäume. Wenige kommen bis hierher — und noch weniger kehren zurück.",
    "Bevor du weiterziehst, verrate mir: was suchst du in meinen Wäldern?"
  ],
  "answers": [
    {
      "text": "Ich reise nur hindurch. Meine Absichten sind rein.",
      "reactionType": "gold",
      "responseText": "Deine Ehrlichkeit gefällt mir. Nimm etwas Gold aus dem Waldschatz mit."
    },
    {
      "text": "Das geht dich nichts an, Elfe!",
      "reactionType": "nothing",
      "responseText": "So spricht also ein Held? Zieh weiter — ohne meinen Segen."
    },
    {
      "text": "Ich suche Rat und Weisheit für meinen Weg.",
      "reactionType": "item",
      "responseText": "Ein weiser Wanderer verdient ein weises Geschenk. Nimm dies mit."
    }
  ]
